// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// AUTHENTICATION
// =============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role     @default(NURSE)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  prescriptions  Prescription[]

  @@map("users")
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  PHARMACIST
}

// =============================================
// PATIENTS (Bệnh nhân)
// =============================================

model Patient {
  id          String    @id @default(cuid())
  code        String    @unique // Mã bệnh nhân (giữ từ hệ thống cũ)
  fullName    String
  dateOfBirth DateTime?
  gender      Gender?
  phone       String?
  email       String?
  address     String?
  occupation  String?
  insurance   String?   // Số BHYT
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  appointments       Appointment[]
  medicalRecords     MedicalRecord[]
  prescriptions      Prescription[]
  invoices           Invoice[]
  programEnrollments ProgramEnrollment[]
  bodyMetrics        BodyMetric[]

  @@map("patients")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// =============================================
// APPOINTMENTS (Lịch hẹn)
// =============================================

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  patient     Patient           @relation(fields: [patientId], references: [id])
  doctorId    String
  doctor      User              @relation(fields: [doctorId], references: [id])
  scheduledAt DateTime
  duration    Int               @default(30) // phút
  status      AppointmentStatus @default(PENDING)
  type        String?           // khám mới, tái khám, gói...
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// =============================================
// MEDICAL RECORDS (Bệnh án)
// =============================================

model MedicalRecord {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id])
  doctorId       String
  doctor         User     @relation(fields: [doctorId], references: [id])
  visitDate      DateTime @default(now())
  chiefComplaint String?  // Lý do khám
  diagnosis      String?  // Chẩn đoán
  treatment      String?  // Hướng điều trị
  vitalSigns     Json?    // Mạch, nhiệt độ, huyết áp, SpO2...
  labResults     String?  // Kết quả xét nghiệm
  imagingResults String?  // Kết quả hình ảnh
  notes          String?
  followUpDate   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("medical_records")
}

// =============================================
// PHARMACY (Kho thuốc & Kê đơn)
// =============================================

model Medicine {
  id            String   @id @default(cuid())
  code          String   @unique // Mã thuốc
  name          String   // Tên thuốc
  genericName   String?  // Hoạt chất
  unit          String   // Đơn vị: viên, ml, gói...
  dosageForm    String?  // Dạng bào chế
  concentration String?  // Hàm lượng: 500mg...
  manufacturer  String?  // Nhà sản xuất
  stockQty      Int      @default(0)
  minStockQty   Int      @default(10) // Mức tồn tối thiểu (cảnh báo)
  costPrice     Decimal  @db.Decimal(12, 2)
  sellPrice     Decimal  @db.Decimal(12, 2)
  expiryDate    DateTime?
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  prescriptionItems PrescriptionItem[]
  stockMovements    StockMovement[]

  @@map("medicines")
}

model StockMovement {
  id         String            @id @default(cuid())
  medicineId String
  medicine   Medicine          @relation(fields: [medicineId], references: [id])
  type       StockMovementType
  quantity   Int               // + nhập, - xuất
  reference  String?           // Số phiếu nhập/xuất
  notes      String?
  createdAt  DateTime          @default(now())

  @@map("stock_movements")
}

enum StockMovementType {
  IN  // Nhập kho
  OUT // Xuất kho
  ADJ // Điều chỉnh
}

model Prescription {
  id        String             @id @default(cuid())
  patientId String
  patient   Patient            @relation(fields: [patientId], references: [id])
  doctorId  String
  doctor    User               @relation(fields: [doctorId], references: [id])
  issuedAt  DateTime           @default(now())
  diagnosis String?
  notes     String?
  status    PrescriptionStatus @default(PENDING)
  items     PrescriptionItem[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@map("prescriptions")
}

enum PrescriptionStatus {
  PENDING   // Chờ cấp phát
  DISPENSED // Đã cấp phát
  CANCELLED
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  medicineId     String
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
  quantity       Int
  dosage         String  // "2 viên/lần"
  frequency      String  // "3 lần/ngày"
  duration       String  // "7 ngày"
  instructions   String? // "Uống sau ăn"

  @@map("prescription_items")
}

// =============================================
// SERVICES (Dịch vụ)
// =============================================

model Service {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  category    String?  // Khám, Xét nghiệm, Thủ thuật...
  price       Decimal  @db.Decimal(12, 2)
  unit        String   @default("lần")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoiceItems InvoiceItem[]

  @@map("services")
}

// =============================================
// BILLING (Thanh toán & Hóa đơn)
// =============================================

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique // HD20240001
  patientId      String
  patient        Patient       @relation(fields: [patientId], references: [id])
  totalAmount    Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @db.Decimal(12, 2) @default(0)
  finalAmount    Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @db.Decimal(12, 2) @default(0)
  status         InvoiceStatus @default(UNPAID)
  paymentMethod  PaymentMethod?
  paymentRef     String?       // Mã giao dịch MoMo/VNPay
  notes          String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items InvoiceItem[]

  @@map("invoices")
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MOMO
  VNPAY
  BANK_TRANSFER
  INSURANCE
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)

  @@map("invoice_items")
}

// =============================================
// PROGRAMS (Gói liệu trình 21 ngày)
// =============================================

model Program {
  id            String   @id @default(cuid())
  name          String   // "Phục hồi đường ruột 21 ngày"
  code          String   @unique // "PHDR21"
  durationWeeks Int      @default(3)
  price         Decimal  @db.Decimal(12, 2)
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  enrollments   ProgramEnrollment[]
  weekTemplates ProgramWeekTemplate[]

  @@map("programs")
}

model ProgramWeekTemplate {
  id          String  @id @default(cuid())
  programId   String
  program     Program @relation(fields: [programId], references: [id])
  weekNumber  Int     // 1, 2, 3
  title       String  // "Tuần 1: Làm sạch đường ruột"
  goals       String  // Mục tiêu tuần
  mealPlan    Json    // { mon: {...}, tue: {...}, ... }
  supplements Json    // [{ name, dosage, timing }]
  activities  String? // Hoạt động thể chất
  tips        String? // Lưu ý đặc biệt

  @@unique([programId, weekNumber])
  @@map("program_week_templates")
}

model ProgramEnrollment {
  id         String           @id @default(cuid())
  patientId  String
  patient    Patient          @relation(fields: [patientId], references: [id])
  programId  String
  program    Program          @relation(fields: [programId], references: [id])
  startDate  DateTime
  endDate    DateTime         // startDate + 21 ngày
  status     EnrollmentStatus @default(ACTIVE)
  invoiceId  String?
  assignedTo String?          // ID tư vấn viên phụ trách
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  weeklyProgress WeeklyProgress[]
  healthMetrics  HealthMetric[]
  notifications  ProgramNotification[]

  @@map("program_enrollments")
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

model WeeklyProgress {
  id              String            @id @default(cuid())
  enrollmentId    String
  enrollment      ProgramEnrollment @relation(fields: [enrollmentId], references: [id])
  weekNumber      Int               // 1, 2, 3
  checkinDate     DateTime          @default(now())
  completedTasks  Json              // { meal: true, supplement: true, exercise: false }
  complianceScore Int?              // % tuân thủ 0-100
  symptoms        Json?             // Triệu chứng trong tuần
  patientFeedback String?           // Phản hồi bệnh nhân
  consultantNotes String?           // Ghi chú tư vấn viên
  nextWeekGoals   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([enrollmentId, weekNumber])
  @@map("weekly_progress")
}

model HealthMetric {
  id             String            @id @default(cuid())
  enrollmentId   String
  enrollment     ProgramEnrollment @relation(fields: [enrollmentId], references: [id])
  weekNumber     Int               // 0 = đầu vào, 1-3 = cuối tuần
  recordedAt     DateTime          @default(now())
  weight         Float?            // kg
  bmi            Float?
  waistCirc      Float?            // Vòng eo cm
  energyLevel    Int?              // 1-10
  digestiveScore Int?              // 1-10
  sleepQuality   Int?              // 1-10
  bloating       Boolean?
  constipation   Boolean?
  diarrhea       Boolean?
  heartburn      Boolean?
  stoolQuality   Int?              // Thang Bristol 1-7
  notes          String?

  @@map("health_metrics")
}

// =============================================
// BODY METRICS (Chỉ số cơ thể - 9 thông số)
// =============================================

model BodyMetric {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])
  recordedAt    DateTime @default(now())
  height        Float?   // Chiều cao (cm)
  weight        Float?   // Cân nặng (kg)
  bmi           Float?   // BMI
  bodyFatPct    Float?   // Mỡ cơ thể (%)
  muscleMass    Float?   // Khối cơ (kg)
  bodyShape     Int?     // Vóc dáng 1-9 (1-3: Béo, 4-6: TB, 7-9: Gầy)
  boneMass      Float?   // Khối xương (kg)
  visceralFat   Float?   // Mỡ nội tạng
  bmr           Float?   // BMR (kcal)
  metabolicAge  Int?     // Tuổi sinh học
  waterPct      Float?   // Tỉ lệ nước cơ thể (%)
  waistCirc     Float?   // Vòng bụng (cm)
  bloodPressure String?  // Huyết áp (VD: "120/80")
  heartRate     Int?     // Nhịp tim (bpm)
  notes         String?
  createdAt     DateTime @default(now())

  @@map("body_metrics")
}

model ProgramNotification {
  id           String            @id @default(cuid())
  enrollmentId String
  enrollment   ProgramEnrollment @relation(fields: [enrollmentId], references: [id])
  type         NotificationType
  channel      String            // "zalo" | "sms"
  message      String
  sentAt       DateTime?
  status       String            @default("pending") // pending|sent|failed
  createdAt    DateTime          @default(now())

  @@map("program_notifications")
}

enum NotificationType {
  WEEKLY_CHECKIN_REMINDER
  SUPPLEMENT_REMINDER
  APPOINTMENT_REMINDER
  PROGRAM_COMPLETE
  CUSTOM
}
